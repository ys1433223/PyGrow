# PyGrow Backend Environment Configuration
# Copy this file to .env and fill in your own values
# =====================================================

# Database
DATABASE_URL=sqlite+aiosqlite:///pygrow.db

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI / LLM
# Supported providers: any OpenAI-compatible API (DeepSeek, Qwen, etc.)
AI_API_KEY=your_api_key_here
AI_BASE_URL=https://api.deepseek.com
AI_MODEL_NAME=deepseek-chat

# ASR (Speech Recognition)
# Supported providers: mock / whisper / aliyun
#   mock    — returns mock transcript (for development without audio files)
#   whisper — local openai-whisper model, works offline, requires `pip install openai-whisper`
#   aliyun  — Aliyun Intelligent Speech Interaction file transcription API (requires OSS)
ASR_PROVIDER=mock
ASR_WHISPER_MODEL=base
ALIYUN_ASR_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ASR_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_ASR_APP_KEY=your_aliyun_app_key

# B站 Cookie（用于下载B站视频，避免 412 反爬）
# 获取方式：浏览器登录B站 → F12 → Application → Cookies → bilibili.com
# 复制所有 cookie 为一行：SESSDATA=xxx; bili_jct=xxx; buvid3=xxx; ...
# 部署到服务器时必填，本地开发可留空（自动尝试读浏览器Cookie）
BILIBILI_COOKIE=
